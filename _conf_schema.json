{
  "video_compress": {
    "description": "视频压缩设置",
    "type": "object",
    "items": {
      "quality": {
        "description": "压缩质量预设",
        "type": "string",
        "options": ["无损压缩", "有损压缩 720p 60", "有损压缩 720p 30", "有损压缩 480p 60", "有损压缩 480p 30", "有损压缩 360p 30"],
        "default": "有损压缩 720p 30"
      },
      "auto_compress": {
        "description": "自动触发压缩视频",
        "type": "bool",
        "default": false,
        "hint": "开启后，当视频文件大小超过阈值时会自动压缩并发回原群"
      },
      "threshold": {
        "description": "自动压缩阈值 (MB)",
        "type": "int",
        "default": 300,
        "hint": "单位：MB，仅当自动触发压缩视频开启时生效。视频超过此大小将被自动压缩"
      },
      "delete_original_after_compress": {
        "description": "压缩后删除临时原视频文件",
        "type": "bool",
        "default": true,
        "hint": "压缩完成后自动清理下载的原视频临时文件，节省磁盘空间"
      }
    }
  },
  "group_control": {
    "description": "群组控制设置",
    "type": "object",
    "items": {
      "mode": {
        "description": "启用模式",
        "type": "string",
        "options": ["黑名单", "白名单"],
        "default": "白名单",
        "hint": "白名单：仅指定群号生效；黑名单：指定群号不生效"
      },
      "group_ids": {
        "description": "群号列表",
        "type": "list",
        "default": [],
        "hint": "填写需要生效或不生效的群号列表（根据启用模式决定）"
      }
    }
  }
}
